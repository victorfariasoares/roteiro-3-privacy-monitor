{
  "manifest_version": 2,
  "name": "Privacy Monitor",
  "version": "1.0.0",
  "description": "Detecta ameaças à privacidade e rastreamento na navegação web.",
  "permissions": [
    "webRequest", "webRequestBlocking",
    "cookies", "storage", "tabs", "activeTab",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["privacy_monitor.js"],
    "persistent": true
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content_script.js"],
    "run_at": "document_start",
    "all_frames": false
  }],
  "sidebar_action": {
    "default_title": "Privacy Monitor",
    "default_panel": "popup.html",
    "default_icon": { "48": "icons/icon48.png", "96": "icons/icon96.png" }
  },
  "browser_action": {
    "default_title": "Privacy Monitor",
    "default_icon": { "48": "icons/icon48.png", "96": "icons/icon96.png" }
  },
  "commands": {
    "_execute_browser_action": {
      "suggested_key": { "default": "Ctrl+Shift+P" },
      "description": "Abrir/fechar Privacy Monitor"
    }
  },
  "icons": { "48": "icons/icon48.png", "96": "icons/icon96.png" }
}
